# Minerva Environment Variables
# Copy this file to .env and fill in actual values

# ============================================
# Backend Configuration
# ============================================

# FastAPI Settings
DEBUG=false
API_TITLE="Minerva Backend"
API_VERSION="0.1.0"

# CORS Configuration (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000"

# ============================================
# OpenRouter LLM Configuration
# ============================================

# OpenRouter API Key - obtain from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk_your_api_key_here

# LLM Model Selection
# Examples: openai/gpt-4-turbo, openai/gpt-4, anthropic/claude-3-opus
RESEARCH_MODEL=openai/gpt-4-turbo

# Retry Policy for OpenRouter API calls
RESEARCH_OPENROUTER_RETRY_COUNT=3
RESEARCH_OPENROUTER_BACKOFF_SECONDS=2.0

# ============================================
# Supabase Configuration
# ============================================

# Supabase Connection Details - obtain from https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Alternative: Direct PostgreSQL Connection String (if using direct connection)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/minerva

# ============================================
# Market Data Configuration
# ============================================

# Path to CSV files containing symbol lists
US_MARKET_SYMBOLS_FILE=data/sp500_symbols.csv
TASE_MARKET_SYMBOLS_FILE=data/tase_symbols.csv

# ============================================
# Frontend Configuration
# ============================================

# Public API URL for frontend (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Development / Testing
# ============================================

# Set to true for verbose logging
VERBOSE_LOGGING=false

# Python path for utilities
PYTHONPATH=.
